{
  "name": "@owdproject/app-atproto",
  "version": "0.0.3",
  "license": "MIT",
  "homepage": "https://github.com/atproto-os/app-atproto",
  "author": {
    "name": "Open Web Desktop Team",
    "url": "https://github.com/owdproject"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "development": "./src/module.ts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "nx": {
    "name": "app-atproto"
  },
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm run dev:prepare && cd playground && pnpm exec nuxt dev",
    "dev:build": "nuxt build playground",
    "dev:generate": "NUXT_APP_BASE_URL=${NUXT_APP_BASE_URL:-/app-atproto/} nuxt generate playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && cd playground && pnpm exec nuxt prepare",
    "validate": "desktop validate ."
  },
  "dependencies": {
    "@nuxt/kit": "^4.3.0",
    "@owdproject/kit-primevue": "workspace:*",
    "@owdproject/kit-tailwind": "workspace:*",
    "@owdproject/module-atproto": "workspace:*"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.3.0",
    "@owdproject/core": "workspace:*",
    "@owdproject/theme-nova": "workspace:*",
    "nuxt": "^4.3.0",
    "typescript": "~5.9.3",
    "@owdproject/module-atproto": "workspace:*",
    "@owdproject/theme-win95": "workspace:*",
    "@owdproject/app-terminal": "workspace:*"
  },
  "peerDependencies": {
    "@owdproject/core": "^3.4.0"
  }
}
